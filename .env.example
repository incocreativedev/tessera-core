# Environment configuration for tessera-core deployment
# Copy to .env.local for local development, .env.staging for staging, etc.

# API Configuration
PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development

# API Features
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_UPLOAD_SIZE=104857600

# Optional: Redis Cache (uncomment to enable)
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL=3600

# Optional: Database (if needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/tessera

# Optional: External Services
# SENTRY_DSN=https://example@sentry.io/123456
# DATADOG_API_KEY=your-key-here

# Security
# API_KEY_SECRET=your-secret-key
# JWT_SECRET=your-jwt-secret

# Deployment-specific (overridden by platform)
# These are set by CI/CD or container orchestration
# DEPLOY_VERSION=latest
# DEPLOY_ENVIRONMENT=production
